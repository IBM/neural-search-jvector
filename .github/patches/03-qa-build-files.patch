diff --git a/qa/build.gradle b/qa/build.gradle
index 9c506aa..582e6b3 100644
--- a/qa/build.gradle
+++ b/qa/build.gradle
@@ -32,13 +32,28 @@ configurations {
 }
 
 def knnJarDirectory = "$rootDir/build/dependencies/opensearch-knn"
+def jvectorJarDirectory = "$buildDir/dependencies/opensearch-jvector"
 
 dependencies {
     api "org.opensearch:opensearch:${opensearch_version}"
     zipArchive group: 'org.opensearch.plugin', name:'opensearch-job-scheduler', version: "${opensearch_build}"
-    zipArchive group: 'org.opensearch.plugin', name:'opensearch-knn', version: "${opensearch_build}"
+
+    // Ensuring only one vector search plugin is on the classpath to avoid jar hell
+    if (isJVectorEngine) {
+        zipArchive group: 'org.opensearch.plugin', name: 'opensearch-jvector-plugin', version: "${jvector_version}"
+    }
+    else {
+        zipArchive group: 'org.opensearch.plugin', name: 'opensearch-knn', version: "${opensearch_build}"
+    }
+
     zipArchive group: 'org.opensearch.plugin', name:'opensearch-ml-plugin', version: "${opensearch_build}"
-    compileOnly fileTree(dir: knnJarDirectory, include: ["opensearch-knn-${opensearch_build}.jar", "remote-index-build-client-${opensearch_build}.jar"])
+
+    if (isJVectorEngine) {
+        compileOnly fileTree(dir: jvectorJarDirectory, include: ["opensearch-jvector-${jvector_version}.jar"])
+    }
+    else {
+        compileOnly fileTree(dir: knnJarDirectory, include: ["opensearch-knn-${opensearch_build}.jar", "remote-index-build-client-${opensearch_build}.jar"])
+    }
     compileOnly group: 'com.google.guava', name: 'guava', version:'32.1.3-jre'
     compileOnly group: 'org.apache.commons', name: 'commons-lang3', version: "${versions.commonslang}"
     // json-path 2.9.0 depends on slf4j 2.0.11, which conflicts with the version used by OpenSearch core.
diff --git a/qa/restart-upgrade/build.gradle b/qa/restart-upgrade/build.gradle
index b4319ef..f73ac81 100644
--- a/qa/restart-upgrade/build.gradle
+++ b/qa/restart-upgrade/build.gradle
@@ -7,6 +7,21 @@ import org.opensearch.gradle.testclusters.StandaloneRestIntegTestTask
 
 apply from : "$rootDir/qa/build.gradle"
 
+// Conditionally exclude BWC tests that use RescoreContext when using jvector
+// RescoreContext is a knn-specific class not available in opensearch-jvector-plugin
+// These tests verify hybrid search with rescoring functionality which requires knn plugin
+// MUST be after apply from to override sourceSets configuration
+if (rootProject.ext.isJVectorEngine) {
+    sourceSets {
+        test {
+            java {
+                exclude '**/bwc/restart/HybridSearchIT.java'
+                exclude '**/bwc/restart/HybridSearchWithRescoreIT.java'
+            }
+        }
+    }
+}
+
 def ext=rootProject.ext
 String baseName = "neuralSearchBwcCluster-restart"
 
